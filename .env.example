# Server
NODE_ENV=development
MCP_PORT=3100
LOG_LEVEL=debug

# Database (local Postgres via Docker Compose)
POSTGRES_PASSWORD=your-postgres-password
DATABASE_URL=postgresql://mcp:your-postgres-password@localhost:5432/workspace_mcp
CREDENTIAL_ENCRYPTION_KEY=your-64-hex-char-key

# Auth
API_KEY=your-api-key-min-32-chars

# CORS
CORS_ORIGINS=

# Microsoft 365
MS_ENABLED=true
MS_CLIENT_ID=
MS_TENANT_ID=common

# Google Workspace
GOOGLE_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3100/auth/google/callback

# IMAP
IMAP_ENABLED=true
